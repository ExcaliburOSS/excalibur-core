{
  "name": "excalibur-core",
  "private": true,
  "version": "1.1.0",
  "description": "Excalibur Core — open-source, local-first developer toolkit for AI-assisted and agentic software development",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config core.hooksPath .husky || true",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify:real": "node scripts/verify-real.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.5"
  }
}
