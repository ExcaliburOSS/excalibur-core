{
  "name": "@excalibur/tui",
  "version": "1.0.0",
  "private": true,
  "description": "Excalibur terminal UI — Ink components and design system for the conversational shell (M-Shell seed)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/rail.cjs",
  "module": "./dist/rail.js",
  "types": "./dist/rail.d.ts",
  "exports": {
    ".": {
      "types": "./dist/rail.d.ts",
      "import": "./dist/rail.js",
      "require": "./dist/rail.cjs"
    },
    "./ink": {
      "types": "./dist/ink/index.d.ts",
      "import": "./dist/ink/index.js",
      "require": "./dist/ink/index.cjs"
    }
  },
  "bin": {
    "excalibur-tui-demo": "./src/demo-timeline.tsx"
  },
  "typesVersions": {
    "*": {
      "ink": [
        "dist/ink/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "demo": "tsx src/demo-timeline.tsx",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@excalibur/shared": "workspace:*",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}
