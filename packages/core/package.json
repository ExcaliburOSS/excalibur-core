{
  "name": "@excalibur/core",
  "version": "1.1.0",
  "private": true,
  "description": "Excalibur core engine: .excalibur config, local runs, artifacts, workflow selection and local phase execution",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@excalibur/agent-runtime": "workspace:*",
    "@excalibur/built-in-extensions": "workspace:*",
    "@excalibur/context-engine": "workspace:*",
    "@excalibur/declarative-schemas": "workspace:*",
    "@excalibur/extension-runtime": "workspace:*",
    "@excalibur/model-gateway": "workspace:*",
    "@excalibur/shared": "workspace:*",
    "@excalibur/workflow-schema": "workspace:*",
    "minimatch": "^10.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}
