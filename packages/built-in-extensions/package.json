{
  "name": "@excalibur/built-in-extensions",
  "version": "0.1.0",
  "description": "Built-in Excalibur extension packs: the default methodologies, workflows, question packs, prompts, artifact templates, policies, reports, roles and command mappings as declarative extensions",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@excalibur/declarative-schemas": "workspace:*",
    "@excalibur/extension-runtime": "workspace:*",
    "@excalibur/model-gateway": "workspace:*",
    "@excalibur/shared": "workspace:*",
    "@excalibur/workflow-schema": "workspace:*",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}
