{
  "name": "@excalibur-oss/excalibur",
  "version": "1.8.1",
  "description": "Excalibur CLI — local-first AI-assisted and agentic development from the terminal",
  "license": "Apache-2.0",
  "author": "ExcaliburOSS",
  "homepage": "https://github.com/ExcaliburOSS/excalibur-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ExcaliburOSS/excalibur-core.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/ExcaliburOSS/excalibur-core/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "agentic",
    "cli",
    "coding-assistant",
    "developer-tools",
    "llm",
    "local-first",
    "excalibur"
  ],
  "type": "commonjs",
  "bin": {
    "excalibur": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-dashboard.mjs",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "prepublishOnly": "pnpm --filter @excalibur/dashboard build && pnpm run build"
  },
  "devDependencies": {
    "@excalibur/agent-runtime": "workspace:*",
    "@excalibur/built-in-extensions": "workspace:*",
    "@excalibur/dashboard": "workspace:*",
    "@excalibur/context-engine": "workspace:*",
    "@excalibur/core": "workspace:*",
    "@excalibur/declarative-schemas": "workspace:*",
    "@excalibur/enterprise-sync": "workspace:*",
    "@excalibur/extension-runtime": "workspace:*",
    "@excalibur-oss/extension-sdk": "workspace:*",
    "@excalibur/model-gateway": "workspace:*",
    "@excalibur/shared": "workspace:*",
    "@excalibur/tui": "workspace:*",
    "@excalibur/work-items": "workspace:*",
    "@excalibur/workflow-schema": "workspace:*",
    "commander": "^13.0.0",
    "picocolors": "^1.1.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "undici": "^8.5.0",
    "vitest": "^3.0.5",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  }
}
