# QuickContract API — environment template. Copy to .env and fill in values.
NODE_ENV=development
PORT=3000

# PostgreSQL connection for Prisma
DATABASE_URL=postgresql://quickcontract:CHANGE_ME@localhost:5432/quickcontract

# Payment provider (names only — real values live outside the repo)
PAYMENT_PROVIDER_API_KEY=CHANGE_ME
PAYMENT_PROVIDER_WEBHOOK_SECRET=CHANGE_ME
